NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Defaults to enabled when Stripe is not configured. Set to false to force the
# checkout API to return 503 instead of the no-money demo checkout page.
PAYMENTS_SANDBOX_CHECKOUT=true
# Set to true only for presenter/demo builds. Unlocks the inline "Reset demo"
# action at the end of each guided workflow. Leave unset (or anything other than
# "true") in production so it never reaches real users.
NEXT_PUBLIC_DEMO_MODE=
