{
  "name": "paddockme",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "npm run typecheck",
    "test:e2e": "playwright test",
    "test:unit": "node --import tsx --test tests/unit/agreement-party.test.ts",
    "check": "npm run lint && npm run build && npm run test:e2e",
    "verify:pitch": "npm run typecheck && npm run docs:check && npm run build && npm run demo:smoke && npm run demo:click",
    "demo:smoke": "node scripts/demo-smoke.mjs",
    "demo:click": "node scripts/demo-click.mjs",
    "payments:smoke": "node scripts/payments-smoke.mjs",
    "docs:check": "node scripts/docs-check.mjs",
    "db:types": "npx supabase gen types typescript --project-id aevzcvlzfvrdipgofczx > src/lib/types/database.ts",
    "typecheck": "tsc --noEmit",
    "start": "node .next/standalone/server.js",
    "start:e2e": "node scripts/standalone-serve.mjs"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.0.2",
    "@googlemaps/markerclusterer": "^2.6.2",
    "@supabase/ssr": "0.10.3",
    "@supabase/supabase-js": "2.105.4",
    "@types/google.maps": "^3.64.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.2.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "playwright": "^1.60.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
